# ScholarRAG configuration.
# Copy to `.env` and fill in as needed. Never commit `.env`.
# Every value has a sensible default in code; override only what you need.

# -- App ---------------------------------------------------------------------
ENVIRONMENT=local            # local | ci | staging | production
LOG_LEVEL=INFO
LOG_JSON=true

# -- LLM (provider-agnostic; Claude is the default) --------------------------
# Providers: anthropic | gemini | openai | ollama
LLM_PROVIDER=anthropic
# Required when LLM_PROVIDER=anthropic (get one at console.anthropic.com).
ANTHROPIC_API_KEY=
# Cheap tier: query rewriting / HyDE / classification.
LLM_MODEL_CHEAP=claude-haiku-4-5
# Strong tier: final grounded generation with citations.
LLM_MODEL_STRONG=claude-sonnet-5
LLM_MAX_OUTPUT_TOKENS=1024

# Query rewriting (Phase 2 Step 3): expand a query into N search variations via
# the cheap tier before retrieving. Off by default; Step 4 wires it in.
# (Needs the `llm` extra for real Claude calls: uv sync --extra llm)
QUERY_REWRITING_ENABLED=false
NUM_QUERY_VARIATIONS=3

# Alternative providers (only needed if you switch LLM_PROVIDER).
# Gemini: set LLM_PROVIDER=gemini + GEMINI_API_KEY to use the free tier instead
# of Claude. Free-tier key from aistudio.google.com — no billing needed.
GEMINI_API_KEY=
GEMINI_MODEL_CHEAP=gemini-3.1-flash-lite
GEMINI_MODEL_STRONG=gemini-3.5-flash
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# -- Embeddings (local sentence-transformers by default; free/on-device) -----
EMBEDDING_PROVIDER=local     # local | openai
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# -- Vector store ------------------------------------------------------------
# auto -> Pinecone when PINECONE_API_KEY is set, else the local fallback.
VECTOR_STORE=auto            # auto | local | pinecone
PINECONE_API_KEY=
PINECONE_INDEX=scholarrag
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1    # free Starter tier is AWS us-east-1 only

# -- Retrieval / reranking (Phase 2) -----------------------------------------
# Hybrid search fuses dense + lexical (RRF), then optionally reranks the
# shortlist with a cross-encoder. "none" = fusion only; "cross_encoder" needs
# the `embeddings` extra (downloads a small model); "fake" is for tests.
RERANKER_PROVIDER=none        # none | cross_encoder | fake
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RETRIEVAL_CANDIDATE_K=50      # stage-1 pool size fed into fusion/rerank
RRF_K=60                      # RRF constant (larger => flatter top-rank weighting)
RETRIEVAL_TOP_K=5            # final chunks fed into the answer prompt (Step 4)

# -- Observability (Phase 4) -------------------------------------------------
# Langfuse LLM tracing (self-hosted; docker compose up -d langfuse -> UI on
# http://localhost:3001). One-time setup: create an account + project in the UI,
# then Project Settings -> API Keys -> copy both keys here. Tracing stays off
# until both keys are set (and `uv sync --extra observability`).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001
# OpenTelemetry app tracing -> Jaeger (docker compose up -d jaeger; UI on
# http://localhost:16686). Off until the endpoint is set.
OTEL_EXPORTER_ENDPOINT=      # http://localhost:4318 to enable
OTEL_SERVICE_NAME=scholarrag

# -- Answer cache (Phase 4) --------------------------------------------------
# Exact + semantic caching of final answers in Redis — a hit skips retrieval AND
# the LLM call. `make seed` clears it (corpus change = stale answers).
CACHE_ENABLED=false          # true to enable (needs Redis)
CACHE_TTL_SECONDS=3600
SEMANTIC_CACHE_ENABLED=true  # paraphrase matching via BGE embeddings
SEMANTIC_CACHE_THRESHOLD=0.93 # cosine floor; raise it if you see false hits

# -- Evaluation (Phase 3) ----------------------------------------------------
EVAL_K=5                     # top-k cutoff for retrieval metrics
EVAL_RECALL_THRESHOLD=0.8    # report floor for Recall@k on the golden set
# Generation eval (Step 2, RAGAS). Needs the `eval` extra: uv sync --extra eval
EVAL_SAMPLE_SIZE=8           # examples per RAGAS run (bounds free-tier cost)
EVAL_MAX_WORKERS=2           # RAGAS judge concurrency (lower = gentler on rate limits)
MLFLOW_TRACKING_URI=         # e.g. http://localhost:5001 ; empty = local ./mlruns

# -- Infrastructure (Phase 1+) ----------------------------------------------
# Host ports are offset (5433/6380) so ScholarRAG coexists with other local
# stacks — see docker-compose.yml. Change these if you run Postgres/Redis elsewhere.
POSTGRES_DSN=postgresql+psycopg://scholarrag:scholarrag@localhost:5433/scholarrag
REDIS_URL=redis://localhost:6380/0

# -- Corpus ------------------------------------------------------------------
# Swappable document domain. See scholarrag.corpus for available profiles.
CORPUS_PROFILE=research_papers
