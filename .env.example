# ScholarRAG configuration.
# Copy to `.env` and fill in as needed. Never commit `.env`.
# Every value has a sensible default in code; override only what you need.

# -- App ---------------------------------------------------------------------
ENVIRONMENT=local            # local | ci | staging | production
LOG_LEVEL=INFO
LOG_JSON=true

# -- LLM (provider-agnostic; Claude is the default) --------------------------
# Providers: anthropic | gemini | openai | ollama
LLM_PROVIDER=anthropic
# Required when LLM_PROVIDER=anthropic (get one at console.anthropic.com).
ANTHROPIC_API_KEY=
# Cheap tier: query rewriting / HyDE / classification.
LLM_MODEL_CHEAP=claude-haiku-4-5
# Strong tier: final grounded generation with citations.
LLM_MODEL_STRONG=claude-sonnet-5
LLM_MAX_OUTPUT_TOKENS=1024

# Alternative providers (only needed if you switch LLM_PROVIDER).
GEMINI_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# -- Embeddings (local sentence-transformers by default; free/on-device) -----
EMBEDDING_PROVIDER=local     # local | openai
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# -- Vector store ------------------------------------------------------------
# auto -> Pinecone when PINECONE_API_KEY is set, else the local fallback.
VECTOR_STORE=auto            # auto | local | pinecone
PINECONE_API_KEY=
PINECONE_INDEX=scholarrag
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1    # free Starter tier is AWS us-east-1 only

# -- Infrastructure (Phase 1+) ----------------------------------------------
POSTGRES_DSN=postgresql+psycopg://scholarrag:scholarrag@localhost:5432/scholarrag
REDIS_URL=redis://localhost:6379/0

# -- Corpus ------------------------------------------------------------------
# Swappable document domain. See scholarrag.corpus for available profiles.
CORPUS_PROFILE=research_papers
