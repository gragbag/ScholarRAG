# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Virtualenv / uv
.venv/
.python-version

# Environment / secrets
.env
.env.*
!.env.example

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*

# Data / models / artifacts (kept out of git).
# NB: `data/*` (children), not `data/` (the dir itself) — git cannot re-include
# anything inside an excluded DIRECTORY, so the negations below only work this way.
data/*
!data/.gitkeep
# ...except the committed sample corpus used by `make seed`.
!data/sample_corpus/
!data/sample_corpus/**
# ...but not the corpus PDFs — too large to commit; the arXiv ids in the
# filenames say where to re-download them for reproducing BENCHMARKS numbers.
data/sample_corpus/*.pdf
# ...and the labelled eval datasets (golden + synthetic) — the benchmark ground truth.
!data/eval/
!data/eval/**
mlruns/
*.log
# Local SQLite stores (MLflow backend, etc.) — runtime artifacts, never committed.
*.db

# Editor / OS
.idea/
.vscode/
.DS_Store
